########################################
# Local environment configuration       #
# (Do NOT commit real secrets)         #
########################################

# Azure (example placeholders)
AZURE_AI_MODEL_DEPLOYMENT="YOUR_AZURE_MODEL_DEPLOYMENT_NAME"
AZURE_AI_ENDPOINT="https://your-azure-endpoint-here"

# GitHub (example placeholders)
GITHUB_MODEL="gpt-4.1-mini"
GITHUB_TOKEN="your_github_token_here"
GITHUB_MODELS_ENDPOINT="https://models.github.ai/inference/chat/completions"
# Jira (example placeholders)
JIRA_BASE_URL="https://your-jira-instance.atlassian.net"
JIRA_PROJECT_KEY="YOUR_JIRA_PROJECT_KEY"
JIRA_API_TOKEN="your_jira_api_token_here"
JIRA_EMAIL="YOUR_JIRA_EMAIL_HERE"
JIRA_ALLOW_WRITES=true

# MCP server (example placeholders)
MCP_JIRA_GITHUB_ENDPOINT="http://localhost:8000"
MCP_ENV="dev"

LLM_MODE=github_models
DEFAULT_LANGUAGE="en"